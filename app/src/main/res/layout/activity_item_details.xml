<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.ItemDetailsActivity">

    <TextView
        android:id="@+id/item_name_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="60sp"
        tools:layout_editor_absoluteX="180dp"
        tools:layout_editor_absoluteY="120dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/item_quantity_text_view" />

    <TextView
        android:id="@+id/item_quantity_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="@id/item_name_text_view"
        app:layout_constraintBottom_toTopOf="@id/item_created_text_view"/>

    <TextView
        android:id="@+id/item_created_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintStart_toStartOf="@id/item_quantity_text_view"
        app:layout_constraintTop_toBottomOf="@id/item_name_text_view"
        app:layout_constraintBottom_toTopOf="@id/item_edit_button"/>

    <TextView
        android:id="@+id/item_updated_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/item_created_text_view"
        app:layout_constraintStart_toStartOf="@id/item_quantity_text_view"/>

    <Button
        android:id="@+id/item_edit_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/edit"
        app:layout_constraintTop_toBottomOf="@id/item_updated_text_view"
        app:layout_constraintStart_toStartOf="@id/item_updated_text_view"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Button
        android:id="@+id/item_delete_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="16dp"
        android:text="@string/delete"
        app:layout_constraintStart_toEndOf="@id/item_edit_button"
        app:layout_constraintTop_toBottomOf="@id/item_updated_text_view"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>